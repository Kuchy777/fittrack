<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment android:id="@+id/splashFragment"
        android:name="com.fittrack.ui.auth.SplashFragment">
        <action android:id="@+id/to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/loginFragment"
        android:name="com.fittrack.ui.auth.LoginFragment">
        <action android:id="@+id/to_register" app:destination="@id/registerFragment"/>
        <action android:id="@+id/login_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/registerFragment"
        android:name="com.fittrack.ui.auth.RegisterFragment">
        <action android:id="@+id/register_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true"/>
    </fragment>

    <!-- MainFragment hostuje BottomNavigation z 4 zakładkami -->
    <fragment android:id="@+id/mainFragment"
        android:name="com.fittrack.ui.navigation.MainFragment">
        <action android:id="@+id/main_to_scanner"
            app:destination="@id/barcodeScannerFragment"/>
        <action android:id="@+id/main_to_recipe_detail"
            app:destination="@id/recipeDetailFragment"/>
        <action android:id="@+id/main_to_workout_map"
            app:destination="@id/workoutMapFragment"/>
    </fragment>

    <fragment android:id="@+id/barcodeScannerFragment"
        android:name="com.fittrack.ui.diary.BarcodeScannerFragment"/>

    <fragment android:id="@+id/recipeDetailFragment"
        android:name="com.fittrack.ui.recipes.RecipeDetailFragment">
        <argument android:name="recipe"
            app:argType="com.fittrack.data.model.RecipeResponse"/>
    </fragment>

    <fragment android:id="@+id/workoutMapFragment"
        android:name="com.fittrack.ui.workout.WorkoutMapFragment"/>
</navigation>
